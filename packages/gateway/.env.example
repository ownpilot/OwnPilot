# OwnPilot Gateway Environment Configuration
# Copy this file to .env only when running the gateway package directly.
# For normal monorepo usage, prefer the root .env.example as the canonical template.
#
# API keys (OpenAI, Anthropic, Gemini, etc.) and channel tokens are NOT
# configured here — use the Config Center UI after setup.

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
# These defaults match the root docker-compose.db.yml and root .env.example.
# Use 127.0.0.1 rather than localhost on Windows because Docker publishes the
# development DB port on IPv4 only.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=25432
POSTGRES_USER=ownpilot
POSTGRES_PASSWORD=ownpilot_secret
POSTGRES_DB=ownpilot

# =============================================================================
# Admin Key (for database export/import/backup operations)
# =============================================================================
# Generate: openssl rand -hex 32
ADMIN_API_KEY=

# =============================================================================
# Application
# =============================================================================
PORT=8080
HOST=127.0.0.1
NODE_ENV=development

# =============================================================================
# Authentication (DB is primary, env is fallback)
# =============================================================================
# Default: api-key. Set AUTH_TYPE=none only for local development.
# AUTH_TYPE=api-key
# API_KEYS=your-secret-key-here
# JWT_SECRET must be at least 64 characters when AUTH_TYPE=jwt.
# Generate: openssl rand -base64 64
# JWT_SECRET=

# =============================================================================
# MQTT
# =============================================================================
# Full URL (takes precedence over individual parts)
MQTT_BROKER_URL=
# Or broken down: host + port (default: mqtt://localhost:1883)
MQTT_BROKER_HOST=localhost
MQTT_PORT=1883
MQTT_WS_PORT=9001

# =============================================================================
# Optional: PGAdmin
# =============================================================================
PGADMIN_EMAIL=admin@ownpilot.local
PGADMIN_PASSWORD=
PGADMIN_PORT=5050

# =============================================================================
# Security hardening (opt-in)
# =============================================================================
# These default to the SECURE behavior. Set to true only if you understand the
# trade-off and need the looser/host-access mode.
#
# Strict callTool gating: when true, custom/extension tools may only call
# read-only or explicitly-permissioned built-in tools (default-deny). Default
# (unset) keeps the looser allow-by-default behavior (dangerous tools are always
# blocked either way via the built-in blocklist).
# OWNPILOT_STRICT_CALLTOOL=true
#
# Allow extensions to opt OUT of the sandbox (runtime.sandbox:"none") and gain
# host fs/exec. Unset = forced into the isolated worker sandbox (recommended).
# OWNPILOT_ENABLE_EXTENSION_HOST_ACCESS=true
#
# Allow coding agents to run in ANY directory. Unset = confined to the workspace
# root (WORKSPACE_DIR) unless you configure allowed dirs in Settings.
# OWNPILOT_CODING_AGENT_ANY_DIR=true
#
# Allow agentskills script_paths to auto-create shell/python/js bridges.
# Unset = skills install but their scripts are not auto-wired as callable tools.
# OWNPILOT_ENABLE_SKILL_SCRIPTS=true
