# OwnPilot Gateway Environment Configuration
# Copy this file to .env only when running the gateway package directly.
# For normal monorepo usage, prefer the root .env.example as the canonical template.
#
# API keys (OpenAI, Anthropic, Gemini, etc.) and channel tokens are NOT
# configured here — use the Config Center UI after setup.

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
# These defaults match the root docker-compose.db.yml and root .env.example.
# Use 127.0.0.1 rather than localhost on Windows because Docker publishes the
# development DB port on IPv4 only.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=25432
POSTGRES_USER=ownpilot
POSTGRES_PASSWORD=ownpilot_secret
POSTGRES_DB=ownpilot

# =============================================================================
# Admin Key (for database export/import/backup operations)
# =============================================================================
# Generate: openssl rand -hex 32
ADMIN_API_KEY=

# =============================================================================
# Application
# =============================================================================
PORT=8080
HOST=127.0.0.1
NODE_ENV=development

# =============================================================================
# Authentication (DB is primary, env is fallback)
# =============================================================================
# Default: api-key. Set AUTH_TYPE=none only for local development.
# AUTH_TYPE=api-key
# API_KEYS=your-secret-key-here
# JWT_SECRET must be at least 64 characters when AUTH_TYPE=jwt.
# Generate: openssl rand -base64 64
# JWT_SECRET=

# =============================================================================
# MQTT
# =============================================================================
# Full URL (takes precedence over individual parts)
MQTT_BROKER_URL=
# Or broken down: host + port (default: mqtt://localhost:1883)
MQTT_BROKER_HOST=localhost
MQTT_PORT=1883
MQTT_WS_PORT=9001

# =============================================================================
# Optional: PGAdmin
# =============================================================================
PGADMIN_EMAIL=admin@ownpilot.local
PGADMIN_PASSWORD=
PGADMIN_PORT=5050
