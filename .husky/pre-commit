#!/usr/bin/env sh

# Ensure tools are on PATH (macOS doesn't inherit shell profile in git hooks)
export PATH="/usr/local/bin:/opt/homebrew/bin:$HOME/.local/bin:$PATH"

# Prevent shell aliases (e.g. cat=bat) from interfering with toolchain
unalias cat 2>/dev/null || true

# Fast path: lint + format only changed files via lint-staged.
# Heavy checks (full typecheck, tests) belong in CI, not the commit gate.
pnpm exec lint-staged
